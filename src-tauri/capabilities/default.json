{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "shell:default",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "cmd", "cmd": "cmd", "args": true },
        { "name": "powershell", "cmd": "powershell", "args": true },
        { "name": "sh", "cmd": "sh", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "node", "cmd": "node", "args": true },
        { "name": "npm", "cmd": "npm", "args": true },
        { "name": "npx", "cmd": "npx", "args": true },
        { "name": "git", "cmd": "git", "args": true }
      ]
    },
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-read-dir",
    "dialog:default",
    "dialog:allow-open",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://openrouter.ai/*" },
        { "url": "https://api.anthropic.com/*" },
        { "url": "https://api.openai.com/*" }
      ]
    }
  ]
}
